# ─────────────────────────────────────────────────────────────────────────────
# OutreachOS production env template
#
# Copy this file, fill in your real keys, then scp to your Oracle VM at
# /tmp/outreach.env before running oracle-setup.sh.
#
#   scp -i ~/.ssh/id_ed25519 outreach.env ubuntu@<your-vm-ip>:/tmp/outreach.env
#
# The setup script will copy this to /home/ubuntu/outreach/.env with mode 600.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001

# ── AI provider ─────────────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=PASTE_YOUR_OPENAI_KEY_HERE
# Optional fallbacks — uncomment and fill if you want
#GEMINI_API_KEY=
#ANTHROPIC_API_KEY=

# ── Scraping providers ──────────────────────────────────────────────────────
APIFY_API_TOKEN=PASTE_YOUR_APIFY_TOKEN_HERE
SERPER_API_KEY=PASTE_YOUR_SERPER_KEY_HERE
APOLLO_API_KEY=PASTE_YOUR_APOLLO_KEY_HERE
HUNTER_API_KEY=PASTE_YOUR_HUNTER_KEY_HERE
PROSPEO_API_KEY=PASTE_YOUR_PROSPEO_KEY_HERE
LINKEDIN_SESSION_COOKIE=PASTE_YOUR_LI_AT_COOKIE_HERE

# ── Supabase (for Phase 4 sqlite → pg migration; not required for Phase 2) ──
SUPABASE_URL=https://dkifhfqgoremdjhkcojc.supabase.co
SUPABASE_SERVICE_ROLE_KEY=PASTE_YOUR_SERVICE_ROLE_KEY_HERE
# DATABASE_URL is filled in during Phase 4
#DATABASE_URL=postgres://postgres:YOUR_DB_PASSWORD@db.dkifhfqgoremdjhkcojc.supabase.co:5432/postgres

# ── Candidate defaults (used by auto-apply form filler) ─────────────────────
CANDIDATE_EMAIL=you@example.com
CANDIDATE_PHONE=000-000-0000

# ── Frontend origin (for CORS) ──────────────────────────────────────────────
FRONTEND_ORIGIN=https://outreach-jt.vercel.app

# ── Feature flags ───────────────────────────────────────────────────────────
# Set to true to disable Playwright auto-apply (useful for Phase 2 smoke test)
DISABLE_AUTO_APPLY=false

# Safety switch — set to true temporarily to wipe DB on next start, then auto-resets
WIPE_DB_ON_START=false

# ── Sheet imports (optional) ────────────────────────────────────────────────
#STARTUP_SHEET_URL=
