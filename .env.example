# Backend
PORT=3001
AI_PROVIDER=gemini

# AI APIs
GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Data & People APIs
APIFY_API_TOKEN=your_apify_token
APOLLO_API_KEY=your_apollo_key
HUNTER_API_KEY=your_hunter_key
PROSPEO_API_KEY=your_prospeo_key
SERPER_API_KEY=your_serper_key

# LinkedIn
LINKEDIN_SESSION_COOKIE=your_li_at_cookie

# Optional: Google Sheets CSV for startup import
STARTUP_SHEET_URL=https://docs.google.com/spreadsheets/d/...

# CORS origins (comma-separated for production)
CORS_ORIGINS=http://localhost:5173

# Supabase Configuration (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Frontend Supabase Configuration (Public)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_sb_publishable_...

# Playwright e2e authentication
E2E_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_sb_publishable_...
E2E_TEST_EMAIL=e2e@example.com
E2E_TEST_PASSWORD=replace_me
E2E_REFRESH_TOKEN=your_e2e_user_refresh_token

# Optional gates surfaced by tests/e2e/deep-audit.spec.js. Set in GitHub
# Actions secrets/vars (or locally) to flip skipped rows to real coverage.
# E2E_AUTO_APPLY_EVAL_ID is auto-populated each run by
# scripts/seed-e2e-fixtures.mjs when SUPABASE_SERVICE_ROLE_KEY is configured.
E2E_AUTO_APPLY_EVAL_ID=
E2E_RUN_REAL_APIFY=
E2E_SECOND_TEST_EMAIL=
E2E_SECOND_TEST_PASSWORD=

# Database (legacy SQLite, commented out for Supabase)
# DB_PATH=data/outreach.db

# Logging
LOG_LEVEL=info

# Development only
WIPE_DB_ON_START=false
